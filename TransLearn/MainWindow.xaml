<Window x:Class="TransLearn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TransLearn.Views"
        Style="{StaticResource MainWindowStyle}"
        Title="TransLearn  – Real-time Translator &amp; Learning Assistant"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="● ● ●"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="10" Margin="0,0,0,12"/>
                    <TextBlock Text="TransLearn"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="실시간 번역 프로그램"
                               FontSize="11"
                               Foreground="{StaticResource TextSecond}"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,0">
                    <Button x:Name="BtnOcr"
                            Style="{StaticResource SidebarButtonActiveStyle}"
                            Click="NavButton_Click" Tag="OCR">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,8,0"/>
                            <TextBlock Text="text 번역"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSound"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavButton_Click" Tag="Sound">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔊" Margin="0,0,8,0"/>
                            <TextBlock Text="sound 번역"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnLearn"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavButton_Click" Tag="Learn">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📖" Margin="0,0,8,0"/>
                            <TextBlock Text="학습모드"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnHistory"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavButton_Click" Tag="History">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🕐" Margin="0,0,8,0"/>
                            <TextBlock Text="번역 기록"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSettings"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavButton_Click" Tag="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Margin="0,0,8,0"/>
                            <TextBlock Text="환경 설정"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Version footer -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0.0"
                           Foreground="{StaticResource TextSecond}"
                           FontSize="11"
                           Margin="16,0,0,16"
                           VerticalAlignment="Bottom"/>
            </DockPanel>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource BgMain}"/>
    </Grid>
</Window>
