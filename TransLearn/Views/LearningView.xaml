<Page x:Class="TransLearn.Views.LearningView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:TransLearn.ViewModels"
      xmlns:conv="clr-namespace:TransLearn.Converters"
      xmlns:models="clr-namespace:TransLearn.Models"
      Background="{StaticResource BgMain}"
      Title="학습모드">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInv" Invert="True"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:LearningViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 + 액션 버튼 ── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="학습 모드" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecond}" FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                <Button Content="🔄 단어 로드"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadWordsFromDbCommand}"
                        Margin="0,0,6,0"/>

                <Button Content="🧠 미분석 문장 분석"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AnalyzeCommand}"
                        Margin="0,0,6,0"/>

                <Button Content="📝 퀴즈 생성"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding GenerateQuizCommand}"
                        Margin="0,0,6,0"/>

                <!-- 난이도 선택 -->
                <Border BorderBrush="#444" BorderThickness="1" CornerRadius="8"
                        Padding="8,6" Margin="6,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="난이도" FontSize="11"
                                   Foreground="{StaticResource TextSecond}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <Button x:Name="DiffBtn1" Content="1" ToolTip="쉬움"
                                Width="34" Height="34" Margin="2,0"
                                FontSize="13" FontWeight="Bold"
                                Background="#2A2A2A" Foreground="#AAAAAA"
                                BorderBrush="#555" BorderThickness="2"
                                Click="DiffBtn_Click" Tag="1"/>

                        <Button x:Name="DiffBtn2" Content="2" ToolTip="보통"
                                Width="34" Height="34" Margin="2,0"
                                FontSize="13" FontWeight="Bold"
                                Background="#1A3A4A" Foreground="#4FC3F7"
                                BorderBrush="#4FC3F7" BorderThickness="2"
                                Click="DiffBtn_Click" Tag="2"/>

                        <Button x:Name="DiffBtn3" Content="3" ToolTip="어려움"
                                Width="34" Height="34" Margin="2,0"
                                FontSize="13" FontWeight="Bold"
                                Background="#2A2A2A" Foreground="#AAAAAA"
                                BorderBrush="#555" BorderThickness="2"
                                Click="DiffBtn_Click" Tag="3"/>

                        <Button x:Name="DiffBtn4" Content="4" ToolTip="매우 어려움"
                                Width="34" Height="34" Margin="2,0"
                                FontSize="13" FontWeight="Bold"
                                Background="#2A2A2A" Foreground="#AAAAAA"
                                BorderBrush="#555" BorderThickness="2"
                                Click="DiffBtn_Click" Tag="4"/>

                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- ── 탭 버튼 ── -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 탭 버튼 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="📚 단어장" Style="{StaticResource PrimaryButton}"
                Click="Tab_WordList" Margin="0,0,6,0"/>
                <Button Content="📝 퀴즈" Style="{StaticResource PrimaryButton}"
                Click="Tab_Quiz"/>
            </StackPanel>

            <!-- 앱 선택 필터 -->
            <Border Grid.Column="2"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8,5"
            VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="가져온 앱"
                       FontSize="11"
                       Foreground="{StaticResource TextSecond}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

                    <ComboBox Width="360"
          Height="34"
          MaxDropDownHeight="260"
          ItemsSource="{Binding SourceApps}"
          SelectedItem="{Binding SelectedSourceApp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          Foreground="Black"
          Background="White"
          BorderBrush="#555"
          Padding="8,4">

                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D8EEFF"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="Black"/>
                        </ComboBox.Resources>

                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Padding" Value="10,7"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="MinHeight" Value="32"/>

                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EAF4FF"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D8EEFF"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                       Foreground="Black"
                       TextTrimming="CharacterEllipsis"
                       FontSize="13"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 로딩 -->
        <Border Grid.Row="2"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="⏳ 분석 중..." FontSize="16"
                       Foreground="{StaticResource TextSecond}"/>
        </Border>

        <!-- ══════════ 단어장 탭 ══════════ -->
        <Grid Grid.Row="2" x:Name="WordListPanel">
            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Background="{StaticResource BgSidebar}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="단어" FontWeight="Bold"
           Foreground="{StaticResource TextSecond}" FontSize="11" Padding="14,8"/>

                        <TextBlock Grid.Column="1" Text="품사" FontWeight="Bold"
           Foreground="{StaticResource TextSecond}" FontSize="11" Padding="4,8"/>

                        <TextBlock Grid.Column="2" Text="빈도" FontWeight="Bold"
           Foreground="{StaticResource TextSecond}" FontSize="11" Padding="4,8"/>

                        <Button Grid.Column="3"
        Background="Transparent"
        BorderThickness="0"
        Padding="4,8"
        Cursor="Hand"
        Command="{Binding SortWordsCommand}"
        CommandParameter="Date">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="날짜" FontWeight="Bold"
                   Foreground="{StaticResource TextSecond}" FontSize="11"/>
                                <TextBlock Text="{Binding DateSortArrow}"
                   Foreground="{StaticResource TextSecond}" FontSize="10"
                   Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4"
        Background="Transparent"
        BorderThickness="0"
        Padding="4,8"
        Cursor="Hand"
        Command="{Binding SortWordsCommand}"
        CommandParameter="Rating">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="평가" FontWeight="Bold"
                   Foreground="{StaticResource TextSecond}" FontSize="11"/>
                                <TextBlock Text="{Binding RatingSortArrow}"
                   Foreground="{StaticResource TextSecond}" FontSize="10"
                   Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Grid.Column="5" Text="예문 (영문)" FontWeight="Bold"
           Foreground="{StaticResource TextSecond}" FontSize="11" Padding="4,8"/>

                        <TextBlock Grid.Column="6" Text="예문 (한국어)" FontWeight="Bold"
           Foreground="{StaticResource TextSecond}" FontSize="11" Padding="4,8"/>

                        <TextBlock Grid.Column="7" Text="👍 / 👎" FontWeight="Bold"
           Foreground="{StaticResource TextSecond}" FontSize="11" Padding="4,8"
           HorizontalAlignment="Center"/>

                        <TextBlock Grid.Column="8" Text="삭제" FontWeight="Bold"
           Foreground="{StaticResource TextSecond}" FontSize="11" Padding="4,8"
           HorizontalAlignment="Center"/>
                    </Grid>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Words}"
                              Background="Transparent" BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background"                 Value="Transparent"/>
                                <Setter Property="BorderThickness"            Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"                Value="{StaticResource BorderColor}"/>
                                <Setter Property="Padding"                    Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:WordEntry}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="45"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Lemma}"
                                               Foreground="{StaticResource TextAccent}"
                                               FontWeight="SemiBold" FontSize="13"
                                               Padding="14,8" VerticalAlignment="Center"/>

                                    <Border Grid.Column="1" Background="{StaticResource BgInput}"
                                            CornerRadius="4" Margin="4,6" Padding="6,2"
                                            VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding PosLabel}" FontSize="10"
                                                   Foreground="{StaticResource TextSecond}"/>
                                    </Border>

                                    <TextBlock Grid.Column="2" Text="{Binding Frequency}"
                                               Foreground="{StaticResource TextGreen}"
                                               FontWeight="Bold" FontSize="13"
                                               Padding="4,8" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding DateLabel}"
           Foreground="{StaticResource TextSecond}"
           FontSize="11"
           Padding="4,8"
           VerticalAlignment="Center"
           HorizontalAlignment="Center"/>

                                    <Border Grid.Column="4" Margin="4,6" Padding="6,2"
                                            CornerRadius="4" VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BgInput}"/>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding RatingLabel}" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecond}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserScore}" Value="1">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserScore}" Value="2">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserScore}" Value="3">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserScore}" Value="-1">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserScore}" Value="-2">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserScore}" Value="-3">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <TextBlock Grid.Column="5" Text="{Binding ExampleSentence}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="11" Padding="4,8"
                                               TextWrapping="Wrap" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="6" Text="{Binding ExampleTranslated}"
                                               Foreground="{StaticResource TextGreen}"
                                               FontSize="11" Padding="4,8"
                                               TextWrapping="Wrap" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="7" Orientation="Horizontal"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Button Content="👍" FontSize="16"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#FFD700" Padding="6,2" Cursor="Hand"
                                                ToolTip="잘 알고 있어요"
                                                Command="{Binding DataContext.RateWordCommand,
                                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="👎" FontSize="16"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#FFD700" Padding="6,2" Cursor="Hand"
                                                ToolTip="어려워요"
                                                Command="{Binding DataContext.DislikeWordCommand,
                                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>

                                    <Button Grid.Column="8" Content="🗑"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#EF5350" FontSize="14" Cursor="Hand"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            ToolTip="이 단어 삭제"
                                            Command="{Binding DataContext.DeleteWordCommand,
                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════ 퀴즈 탭 ══════════ -->
        <Grid Grid.Row="2" x:Name="QuizPanel" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding QuizFinished, Converter={StaticResource BoolVis}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Padding="40,30">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🏆 퀴즈 완료!" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock HorizontalAlignment="Center" FontSize="18">
                                <Run Text="{Binding QuizScore}" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                                <Run Text=" / " Foreground="{StaticResource TextSecond}"/>
                                <Run Text="{Binding QuizTotal}" Foreground="{StaticResource TextPrimary}"/>
                                <Run Text=" 정답" Foreground="{StaticResource TextSecond}"/>
                            </TextBlock>
                            <TextBlock Text="단어장의 평가가 업데이트되었습니다."
                                       Foreground="{StaticResource TextSecond}" FontSize="12"
                                       HorizontalAlignment="Center" Margin="0,8,0,16"/>
                            <Button Content="🔄 다시 풀기"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding GenerateQuizCommand}"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding QuizFinished, Converter={StaticResource BoolVisInv}}"
                            MaxWidth="620" HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,20,0,20" Padding="30">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Foreground="{StaticResource TextSecond}" FontSize="12">
                                        <Run Text="{Binding CurrentQuizIndex}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding QuizTotal}"/>
                                    </TextBlock>
                                    <Border Background="{StaticResource BgInput}" CornerRadius="4"
                                            Width="160" Height="6" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <Border Background="{StaticResource AccentGreen}" CornerRadius="4"
                                                HorizontalAlignment="Left" Height="6">
                                            <Border.Width>
                                                <MultiBinding>
                                                    <MultiBinding.Converter>
                                                        <conv:ProgressWidthConverter/>
                                                    </MultiBinding.Converter>
                                                    <Binding Path="CurrentQuizIndex"/>
                                                    <Binding Path="QuizTotal"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Foreground="{StaticResource AccentGreen}" FontWeight="Bold">
                                    <Run Text="점수: "/><Run Text="{Binding QuizScore}"/>
                                </TextBlock>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="{StaticResource BgInput}"
            CornerRadius="6"
            Padding="8,3"
            Margin="0,0,8,0">
                                    <TextBlock Text="{Binding CurrentQuiz.TypeLabel}"
                   Foreground="{StaticResource AccentGreen}"
                   FontSize="11"
                   FontWeight="Bold"/>
                                </Border>

                                <TextBlock Text="{Binding CurrentQuiz.Question}"
               Foreground="{StaticResource TextPrimary}"
               FontSize="15"
               FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- [수정] 예문 + 번역문 함께 표시 -->
                            <Border Background="{StaticResource BgInput}" CornerRadius="8"
                                    Padding="16,12" Margin="0,0,0,20">
                                <StackPanel>
                                    <!-- 영문 예문 -->
                                    <TextBlock Text="{Binding CurrentQuiz.Sentence}"
                                               Foreground="{StaticResource TextAccent}"
                                               FontSize="14" TextWrapping="Wrap"/>
                                    <!-- 한국어 번역문 -->
                                    <TextBlock Text="{Binding CurrentQuiz.Translation}"
                                               Foreground="{StaticResource TextGreen}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- 객관식 선지 -->
                            <ItemsControl ItemsSource="{Binding CurrentQuiz.Choices}"
              Visibility="{Binding CurrentQuiz.IsMultipleChoice, Converter={StaticResource BoolVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Stretch" Margin="0,4"
                    Command="{Binding DataContext.AnswerQuizCommand,
                              RelativeSource={RelativeSource AncestorType=Page}}"
                    CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 서술형 입력 -->
                            <StackPanel Visibility="{Binding CurrentQuiz.IsShortAnswer, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="빈칸에 들어갈 단어를 직접 입력하세요."
               Foreground="{StaticResource TextSecond}"
               FontSize="12"
               Margin="0,0,0,8"/>

                                <TextBox Text="{Binding ShortAnswerInput, UpdateSourceTrigger=PropertyChanged}"
         MinHeight="44"
         FontSize="15"
         Padding="10,0"
         VerticalContentAlignment="Center"
         Background="{StaticResource BgInput}"
         Foreground="{StaticResource TextPrimary}"
         BorderBrush="#555"
         BorderThickness="1"
         Margin="0,0,0,10"/>

                                <Button Content="제출"
            Style="{StaticResource PrimaryButton}"
            HorizontalAlignment="Stretch"
            Command="{Binding SubmitShortAnswerCommand}"/>
                            </StackPanel>

                            <Border Margin="0,16,0,0" Padding="12,8"
                                    Background="{StaticResource BgInput}" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="이 단어에 대한 중요도를 평가해 주세요:"
                                               Foreground="{StaticResource TextSecond}"
                                               FontSize="11" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button FontSize="22" Background="Transparent" BorderThickness="0"
                                                Padding="12,4" Cursor="Hand" Foreground="#FFD700"
                                                ToolTip="중요해요 👍"
                                                Command="{Binding RateQuizItemCommand}"
                                                CommandParameter="{Binding CurrentQuiz}">👍</Button>
                                        <TextBlock Text="중요해요" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecond}"
                                                   FontSize="12" Margin="0,0,20,0"/>
                                        <Button FontSize="22" Background="Transparent" BorderThickness="0"
                                                Padding="12,4" Cursor="Hand" Foreground="#FFD700"
                                                ToolTip="별로에요 👎"
                                                Command="{Binding DislikeQuizItemCommand}"
                                                CommandParameter="{Binding CurrentQuiz}">👎</Button>
                                        <TextBlock Text="별로에요" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecond}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
