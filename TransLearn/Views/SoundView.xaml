<!--
    SoundView.xaml
    역할 : 오디오 캡처 + STT + 번역 기능의 메인 UI.
-->
<Page x:Class="TransLearn.Views.SoundView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:TransLearn.ViewModels"
      xmlns:conv="clr-namespace:TransLearn.Converters"
      xmlns:models="clr-namespace:TransLearn.Models"
      Background="{StaticResource BgMain}"
      Title="Sound 번역">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInv" Invert="True"/>
        <conv:RunningBrushConverter     x:Key="RunBrush"/>

        <Style x:Key="VuMeterStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="7" Background="#1E293B" ClipToBounds="True"
                                BorderBrush="#334155" BorderThickness="1">
                            <Grid>
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left" CornerRadius="7">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00E676" Offset="0.00"/>
                                            <GradientStop Color="#76FF03" Offset="0.45"/>
                                            <GradientStop Color="#FFEA00" Offset="0.70"/>
                                            <GradientStop Color="#FF6D00" Offset="0.85"/>
                                            <GradientStop Color="#FF1744" Offset="1.00"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="False"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Page.DataContext>
        <vm:SoundViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: STT 상태 배너 ── -->
        <Border Grid.Row="0" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#7B3A00"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SttConfigured}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding SttInfoText}"
                       Foreground="#FFD54F" TextWrapping="Wrap" FontSize="12"/>
        </Border>

        <Border Grid.Row="0" Background="#0D1F3C" CornerRadius="8"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding SttConfigured, Converter={StaticResource BoolVis}}">
            <TextBlock Text="{Binding SttInfoText}"
                       Foreground="#64B5F6" TextWrapping="Wrap" FontSize="11"/>
        </Border>

        <!-- ── Row 1: 툴바 ── -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{Binding IsRunning, Converter={StaticResource RunBrush}}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecond}" FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="🎵 오디오 번역"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- [수정] 자막 레이어 버튼 추가 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="📺 자막 레이어"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ToggleOverlayCommand}"
                            Margin="0,0,6,0"/>
                    <Button Content="▶ 시작" Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolVisInv}}"
                            Margin="0,0,6,0"/>
                    <Button Content="⏹ 중지" Style="{StaticResource StopButton}"
                            Command="{Binding StopCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Row 2: VU 미터 ── -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}"
                Margin="0,0,0,8"
                Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
            <Grid Margin="14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#334155"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <ColorAnimation
                                                        Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                                        From="#00E676" To="#334155"
                                                        Duration="0:0:1" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="오디오" Foreground="{StaticResource TextSecond}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                    <ProgressBar Style="{StaticResource VuMeterStyle}"
                                 Value="{Binding AudioLevel}"/>
                    <Canvas Height="14" ClipToBounds="False">
                        <Rectangle Canvas.Left="{Binding PeakPosition}"
                                   Width="2" Height="14"
                                   Fill="White" Opacity="0.75"
                                   RadiusX="1" RadiusY="1"/>
                    </Canvas>
                </Grid>

                <TextBlock Grid.Column="2" Text="{Binding AudioLevelDb}"
                           Foreground="{StaticResource TextSecond}"
                           FontSize="10" FontFamily="Consolas"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Row 3: 대상 앱 선택 ── -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="대상 앱 (참고용):"
                           Foreground="{StaticResource TextSecond}"
                           VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding RunningApps}"
                          SelectedItem="{Binding SelectedApp}"
                          Margin="0,0,8,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="Black" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2" Content="🔄 새로고침"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RefreshAppsCommand}"/>
            </Grid>
        </Border>

        <!-- ── Row 4: 품질 필터 통계 ── -->
        <Border Grid.Row="4" Background="#1A2233"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="8"
                Padding="12,7" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍 품질 필터"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding DiscardRateText}"
                               Foreground="#FF9800" FontSize="11"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding LastRejectReason}"
                           Foreground="#EF5350" FontSize="11" FontStyle="Italic"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ── Row 5: 중간 인식 결과 ── -->
        <Border Grid.Row="5" Background="{StaticResource BgCard}"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
            <TextBlock Text="{Binding InterimText}"
                       Foreground="{StaticResource TextSecond}"
                       FontStyle="Italic" FontSize="12"
                       TextWrapping="Wrap" MinHeight="20"/>
        </Border>

        <!-- ── Row 6: 메인 콘텐츠 ── -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource SectionHeader}"
                                Background="{StaticResource HeaderOrig}">
                            <TextBlock Text="원문" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <TextBox Grid.Row="1" Text="{Binding OriginalText, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextAccent}"
                                 FontSize="14" Margin="14,10"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource SectionHeader}"
                                Background="{StaticResource HeaderTrans}">
                            <TextBlock Text="번역문" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <TextBox Grid.Row="1" Text="{Binding TranslatedText, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextGreen}"
                                 FontSize="14" Margin="14,10"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 최근 번역 기록 사이드바 -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource BgSidebar}"
                            CornerRadius="10,10,0,0" Padding="12,10">
                        <TextBlock Text="최근 번역 기록" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                    </Border>
                    <ListView Grid.Row="1" ItemsSource="{Binding RecentItems}"
                              Background="Transparent" BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:TranslationRecord}">
                                <Border Padding="8,6"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding OriginalText}"
                                                   Foreground="{StaticResource TextAccent}"
                                                   FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Translated}"
                                                   Foreground="{StaticResource TextGreen}"
                                                   FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding TimeLabel}"
                                                   Foreground="{StaticResource TextSecond}"
                                                   FontSize="10"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
