<Window x:Class="TransLearn.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TransLearn Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="600" Height="130"
        MouseMove="Window_MouseMove"
        MouseLeave="Window_MouseLeave"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <!-- 자막 본체 -->
        <Border x:Name="MainBorder" CornerRadius="8" Background="#BB000000">
            <StackPanel Margin="16,8" VerticalAlignment="Center">

                <!-- 이전 번역 (흐릿하게) -->
                <TextBlock x:Name="PrevTranslationText"
                           Text=""
                           Foreground="#88FFFFFF"
                           FontSize="14"
                           FontWeight="Normal"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,4"
                           Visibility="Collapsed">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="4"
                                          ShadowDepth="1" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- 현재 번역 (밝게) -->
                <TextBlock x:Name="TranslationText"
                           Text="번역 대기 중..."
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="6"
                                          ShadowDepth="1" Opacity="1.0"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 호버 컨트롤 패널 -->
        <Border x:Name="ControlPanel"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,6,0" Opacity="0"
                Background="#CC111111" Padding="4,3">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Button Content="A-" Width="24" Height="24" FontSize="10"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" Cursor="Hand" Margin="1,0"
                        Click="FontSizeDown_Click"/>
                <Button Content="A+" Width="24" Height="24" FontSize="10"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" Cursor="Hand" Margin="1,0"
                        Click="FontSizeUp_Click"/>

                <Rectangle Width="1" Fill="#44FFFFFF" Margin="3,2"/>

                <!-- 이전 번역 표시 토글 -->
                <Button x:Name="PrevToggleBtn" Content="≡" Width="24" Height="24" FontSize="14"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888888" Cursor="Hand" Margin="1,0"
                        Click="PrevToggleBtn_Click" ToolTip="이전 번역 표시 ON/OFF"/>

                <Rectangle Width="1" Fill="#44FFFFFF" Margin="3,2"/>

                <Button x:Name="ColorPickerBtn" Content="🎨" Width="24" Height="24" FontSize="12"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" Cursor="Hand" Margin="1,0"
                        Click="ColorPickerBtn_Click" ToolTip="배경색 선택"/>

                <!-- 컬러 피커 팝업 -->
                <Popup x:Name="ColorPopup" PlacementTarget="{Binding ElementName=ColorPickerBtn}"
                       Placement="Bottom" StaysOpen="False">
                    <Border Background="#EE1E1E1E" Padding="6">
                        <WrapPanel Width="160">
                            <Rectangle Width="20" Height="20" Fill="#000000" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#000000"/>
                            <Rectangle Width="20" Height="20" Fill="#212121" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#212121"/>
                            <Rectangle Width="20" Height="20" Fill="#37474F" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#37474F"/>
                            <Rectangle Width="20" Height="20" Fill="#1A237E" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#1A237E"/>
                            <Rectangle Width="20" Height="20" Fill="#0D47A1" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#0D47A1"/>
                            <Rectangle Width="20" Height="20" Fill="#006064" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#006064"/>
                            <Rectangle Width="20" Height="20" Fill="#1B5E20" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#1B5E20"/>
                            <Rectangle Width="20" Height="20" Fill="#33691E" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#33691E"/>
                            <Rectangle Width="20" Height="20" Fill="#827717" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#827717"/>
                            <Rectangle Width="20" Height="20" Fill="#E65100" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#E65100"/>
                            <Rectangle Width="20" Height="20" Fill="#4A148C" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#4A148C"/>
                            <Rectangle Width="20" Height="20" Fill="#880E4F" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#880E4F"/>
                            <Rectangle Width="20" Height="20" Fill="#B71C1C" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#B71C1C"/>
                            <Rectangle Width="20" Height="20" Fill="#4E342E" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#4E342E"/>
                            <Rectangle Width="20" Height="20" Fill="#263238" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#263238"/>
                            <Rectangle Width="20" Height="20" Fill="#87CEEB" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#87CEEB"/>
                            <Rectangle Width="20" Height="20" Fill="#4FC3F7" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#4FC3F7"/>
                            <Rectangle Width="20" Height="20" Fill="#80DEEA" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#80DEEA"/>
                            <Rectangle Width="20" Height="20" Fill="#FFEB3B" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#FFEB3B"/>
                            <Rectangle Width="20" Height="20" Fill="#FFF176" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#FFF176"/>
                            <Rectangle Width="20" Height="20" Fill="#FFCC80" Margin="2" Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click" Tag="#FFCC80"/>
                        </WrapPanel>
                    </Border>
                </Popup>

                <Rectangle Width="1" Fill="#44FFFFFF" Margin="3,2"/>

                <TextBlock Text="투명" Foreground="#88FFFFFF" FontSize="9"
                           VerticalAlignment="Center" Margin="2,0"/>
                <Slider x:Name="OpacitySlider"
                        Width="70" Minimum="0" Maximum="255"
                        Value="187" VerticalAlignment="Center" Margin="2,0"
                        ValueChanged="OpacitySlider_ValueChanged"/>
                <TextBlock Text="불투명" Foreground="#88FFFFFF" FontSize="9"
                           VerticalAlignment="Center" Margin="2,0"/>

                <Rectangle Width="1" Fill="#44FFFFFF" Margin="3,2"/>

                <Button x:Name="PinBtn" Content="📌" Width="24" Height="24" FontSize="12"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888888" Cursor="Hand" Margin="1,0"
                        Click="PinBtn_Click" ToolTip="항상 위에 고정"/>

                <Rectangle Width="1" Fill="#44FFFFFF" Margin="3,2"/>

                <Button Content="✕" Width="24" Height="24" FontSize="12"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#FF6666" Cursor="Hand" Margin="1,0"
                        Click="Close_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
