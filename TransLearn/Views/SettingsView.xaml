<!--
    SettingsView.xaml
    역할 : 앱 환경설정 화면.

    섹션 구성
      1. 번역 설정      — 번역 방법(Google/DeepL) + 문맥 크기
      2. DeepL API 키   — PasswordBox + DPAPI 저장
      3. STT 엔진 설정  — Windows 내장 STT / Azure STT 선택 + 저장
         └ Azure 키 섹션 — Azure STT 선택 시만 표시
      4. 데이터 초기화  — 전체 DB 삭제 (독립 카드)
-->
<Page x:Class="TransLearn.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:TransLearn.ViewModels"
      xmlns:conv="clr-namespace:TransLearn.Converters"
      Background="{StaticResource BgMain}"
      Title="환경 설정">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInv" Invert="True"/>
        <conv:BoolToStringConverter     x:Key="KeyStatus"
                                        TrueValue="✅ 키 등록됨"
                                        FalseValue="❌ 미등록"/>
        <conv:NotEmptyVisibilityConverter x:Key="NotEmptyVis"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="700">

            <TextBlock Text="환경 설정" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- 1. 번역 설정                                               -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel Margin="20,16">
                    <TextBlock Text="번역 설정" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                    <!-- 번역 방법 선택 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="번역 방법" Foreground="{StaticResource TextSecond}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider}"
                                  Foreground="Black">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="Black" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <!-- 문맥 크기 슬라이더 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="문맥 크기 (N)" Foreground="{StaticResource TextSecond}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="1" Maximum="10" Value="{Binding ContextSize}"
                                    Width="200" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ContextSize}" Margin="10,0,0,0"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="💾 설정 저장" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveSettingsCommand}"
                            HorizontalAlignment="Left" Margin="0,8,0,0"/>

                    <TextBlock Text="{Binding DeepLStatus}" Foreground="{StaticResource TextGreen}"
                               FontSize="12" Margin="0,8,0,0"
                               Visibility="{Binding DeepLStatus, Converter={StaticResource NotEmptyVis}}"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- 2. DeepL API 키                                           -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel Margin="20,16">
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DeepL API 키" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <Border Grid.Column="1" Background="{StaticResource BgInput}"
                                CornerRadius="4" Padding="8,4">
                            <TextBlock Text="{Binding DeepLKeySet, Converter={StaticResource KeyStatus}}"
                                       FontSize="12" Foreground="{StaticResource TextSecond}"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="Windows DPAPI로 로컬 암호화 저장됩니다."
                               Foreground="{StaticResource TextSecond}" FontSize="11"
                               Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DeepL API 키:" Foreground="{StaticResource TextSecond}"
                                   VerticalAlignment="Center"/>
                        <PasswordBox Grid.Column="1" x:Name="PbDeepL"
                                     PasswordChanged="PbDeepL_PasswordChanged"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="💾 저장" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveDeepLKeyCommand}" Margin="0,0,8,0"/>
                        <Button Content="🗑 삭제" Style="{StaticResource StopButton}"
                                Command="{Binding DeleteDeepLKeyCommand}"
                                Visibility="{Binding DeepLKeySet, Converter={StaticResource BoolVis}}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding DeepLStatus}" Foreground="{StaticResource TextGreen}"
                               FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- 3. STT 엔진 설정                                           -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel Margin="20,16">

                    <TextBlock Text="🎙 음성 인식 (STT) 엔진" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecond}"
                               Margin="0,0,0,14" TextWrapping="Wrap">
                        Windows 내장 STT는 API 키 없이 무료로 사용할 수 있습니다.
                        Azure STT는 클라우드 처리로 더 높은 정확도를 제공합니다 (월 5시간 무료).
                    </TextBlock>

                    <!-- 엔진 선택 ComboBox -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="STT 엔진:" Foreground="{StaticResource TextSecond}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding SttEngines}"
                                  SelectedItem="{Binding SelectedSttEngine}"
                                  Foreground="Black">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="Black" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <!-- 저장 버튼 -->
                    <Button Content="💾 엔진 저장" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveSttEngineCommand}"
                            HorizontalAlignment="Left" Margin="0,0,0,12"/>

                    <!-- 상태 설명 박스 -->
                    <Border Background="{StaticResource BgInput}" CornerRadius="6"
                            Padding="12,10" Margin="0,0,0,4"
                            Visibility="{Binding SttEngineStatus, Converter={StaticResource NotEmptyVis}}">
                        <TextBlock Text="{Binding SttEngineStatus}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- ── Azure STT 키 입력 섹션 (Azure 선택 시만 표시) ── -->
                    <Border Margin="0,16,0,0"
                            Visibility="{Binding ShowAzureSection, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <Separator Margin="0,0,0,12" Background="{StaticResource BorderColor}"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Azure STT API 키" FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <Border Grid.Column="1" Background="{StaticResource BgInput}"
                                        CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="{Binding AzureKeySet, Converter={StaticResource KeyStatus}}"
                                               FontSize="12" Foreground="{StaticResource TextSecond}"/>
                                </Border>
                            </Grid>

                            <TextBlock Foreground="{StaticResource TextSecond}" FontSize="11"
                                       Margin="0,0,0,12" TextWrapping="Wrap">
                                Azure Portal → Cognitive Services → Speech 리소스에서 키를 발급받으세요.
                                무료 티어(F0): 월 5시간 음성 인식 무료 제공.
                            </TextBlock>

                            <!-- Azure 키 입력 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Azure 키:" Foreground="{StaticResource TextSecond}"
                                           VerticalAlignment="Center"/>
                                <PasswordBox Grid.Column="1" x:Name="PbAzure"
                                             PasswordChanged="PbAzure_PasswordChanged"/>
                            </Grid>

                            <!-- 리전 입력 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="리전:" Foreground="{StaticResource TextSecond}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding AzureRegion}"
                                         ToolTip="예: eastus, koreacentral, japaneast"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="💾 저장" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding SaveAzureKeyCommand}" Margin="0,0,8,0"/>
                                <Button Content="🗑 삭제" Style="{StaticResource StopButton}"
                                        Command="{Binding DeleteAzureKeyCommand}"
                                        Visibility="{Binding AzureKeySet, Converter={StaticResource BoolVis}}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding AzureStatus}"
                                       Foreground="{StaticResource TextGreen}"
                                       FontSize="12" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
            <!-- STT 카드 끝 ↑ -->

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- 4. 데이터 초기화  (STT 카드와 독립된 별도 카드)            -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel Margin="20,16">
                    <TextBlock Text="⚠️ 데이터 초기화" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="모든 번역 기록과 단어장을 영구적으로 삭제합니다. 되돌릴 수 없습니다."
                               Foreground="{StaticResource TextSecond}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button Content="🗑 전체 DB 초기화"
                            Style="{StaticResource StopButton}"
                            Command="{Binding ResetDatabaseCommand}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ResetStatus}"
                               Foreground="#EF5350" FontSize="12" Margin="0,8,0,0"
                               Visibility="{Binding ResetStatus, Converter={StaticResource NotEmptyVis}}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
