<Window x:Class="TransLearn.Views.OcrRegionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR 캡처 영역"
        Width="300" Height="220"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Semi-transparent dark background -->
        <Border Background="#AA1A1F2E"
                BorderBrush="#4064B5F6"
                BorderThickness="2"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="#BB141824"
                        CornerRadius="6,6,0,0"
                        MouseLeftButtonDown="TitleBar_MouseDown"
                        Cursor="SizeAll">
                    <Grid>
                        <TextBlock Text="OCR 캡처 영역" Foreground="#64B5F6"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Button Content="✕" Width="24" Height="24"
                                HorizontalAlignment="Right" Margin="0,0,4,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#8892A4" Cursor="Hand"
                                Click="Close_Click"/>
                    </Grid>
                </Border>

                <!-- Crosshair center -->
                <Grid Grid.Row="1">
                    <TextBlock Text="+" FontSize="24" Foreground="#4064B5F6"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Confirm button -->
                <Border Grid.Row="2" Background="#BB141824" CornerRadius="0,0,6,6">
                    <Button Content="✅ 이 영역으로 설정"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#2979FF" Foreground="White"
                            BorderThickness="0" Padding="12,6" Cursor="Hand"
                            Click="Confirm_Click"/>
                </Border>
            </Grid>
        </Border>

        <!-- Resize grip indicator (corner) -->
        <TextBlock Text="⊿" Foreground="#4064B5F6" FontSize="14"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,4,4"
                   IsHitTestVisible="False"/>
    </Grid>
</Window>
