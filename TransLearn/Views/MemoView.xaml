<Page x:Class="TransLearn.Views.MemoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:TransLearn.ViewModels"
      Background="{StaticResource BgMain}"
      Title="메모장">

    <Page.DataContext>
        <vm:MemoViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="메모장"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="{Binding TotalCount, StringFormat='총 {0}개'}"
                           Foreground="{StaticResource TextSecond}"
                           FontSize="12"/>
            </StackPanel>

        </Grid>

        <!-- 입력 영역 -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,12"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="메모할 영어 단어 또는 문장"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding MemoContent, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="70"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="설명"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding MemoDescription, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="70"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="＋ 새 메모"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Command="{Binding NewMemoCommand}"/>

                    <Button Content="💾 저장"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveMemoCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 목록 영역 -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 검색 -->
                <Border Grid.Row="0"
                        Background="{StaticResource BgSidebar}"
                        CornerRadius="10,10,0,0"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

						<TextBox Grid.Column="0"
							   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
							   MinHeight="38"
							   Padding="12,6"
							   VerticalContentAlignment="Center"
							   FontSize="13"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextSecond}"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </Grid>
                </Border>

                <!-- 헤더 -->
                <Grid Grid.Row="1"
                      Background="{StaticResource BgSidebar}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="메모"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="11"
                               Padding="14,8"/>

                    <TextBlock Grid.Column="1"
                               Text="설명"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="11"
                               Padding="4,8"/>

                    <Button Grid.Column="2"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4,8"
                            Cursor="Hand"
                            Command="{Binding SortByDateCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="날짜"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextSecond}"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding DateSortArrow}"
                                       Foreground="{StaticResource TextSecond}"
                                       FontSize="10"
                                       Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="3"
                               Text="삭제"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="11"
                               Padding="4,8"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- 리스트 -->
                <ListView Grid.Row="2"
                          ItemsSource="{Binding Memos}"
                          SelectedItem="{Binding SelectedMemo, Mode=TwoWay}"
                          Background="Transparent"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#263B4A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="54">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Content}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Padding="14,8"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Description}"
                                           Foreground="{StaticResource TextSecond}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Padding="4,8"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding DateLabel}"
                                           Foreground="{StaticResource TextAccent}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Padding="4,8"/>

                                <Button Grid.Column="3"
                                        Content="🗑"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#EF5350"
                                        FontSize="14"
                                        Cursor="Hand"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        ToolTip="메모 삭제"
                                        Command="{Binding DataContext.DeleteMemoCommand,
                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="목록에서 메모를 클릭하면 위 입력칸에서 수정할 수 있습니다."
                   Foreground="{StaticResource TextSecond}"
                   FontSize="11"
                   Margin="2,8,0,0"/>
    </Grid>
</Page>