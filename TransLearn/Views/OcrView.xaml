<Page x:Class="TransLearn.Views.OcrView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:TransLearn.ViewModels"
      xmlns:conv="clr-namespace:TransLearn.Converters"
      Background="{StaticResource BgMain}"
      Title="OCR 번역">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInv" Invert="True"/>
        <conv:RunningBrushConverter x:Key="RunBrush"/>
        <conv:BoolToStringConverter x:Key="BoolBtn" TrueValue="⏸ 일시정지" FalseValue="▶ 재개"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:OcrViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── TOOLBAR ── -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{Binding IsRunning, Converter={StaticResource RunBrush}}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecond}" FontSize="12"/>
                </StackPanel>

                <!-- Region info -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CaptureRegionInfo}"
                           Foreground="{StaticResource TextAccent}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Control buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="🖱 캡처 영역 설정"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SetCaptureRegionCommand}"
                            Margin="0,0,6,0"/>
                    <Button Content="▶ 시작"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolVisInv}}"
                            Margin="0,0,6,0"/>
                    <Button Content="{Binding IsPaused, Converter={StaticResource BoolBtn}}"
                            Style="{StaticResource PauseButton}"
                            Command="{Binding PauseCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"
                            Margin="0,0,6,0"/>
                    <Button Content="⏹ 중지"
                            Style="{StaticResource StopButton}"
                            Command="{Binding StopCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── FILTER STATS BAR ── -->
        <Border Grid.Row="1"
                Background="#1A2233"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="8"
                Padding="12,7" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 필터 레이블 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍 품질 필터"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding DiscardRateText}"
                               Foreground="#FF9800" FontSize="11"/>
                </StackPanel>

                <!-- 마지막 폐기 이유 -->
                <TextBlock Grid.Column="1"
                           Text="{Binding LastRejectReason}"
                           Foreground="#EF5350"
                           FontSize="11" FontStyle="Italic"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- 통계 리셋 버튼 -->
                <Button Grid.Column="2"
                        Content="초기화"
                        Background="Transparent"
                        Foreground="{StaticResource TextSecond}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BorderColor}"
                        Padding="8,2" FontSize="10"
                        Cursor="Hand"
                        Command="{Binding ResetStatsCommand}"/>
            </Grid>
        </Border>

        <!-- ── WINDOW TARGET ── -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="대상 창 (선택사항):"
                           Foreground="{StaticResource TextSecond}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Windows}"
                          SelectedItem="{Binding SelectedWindow}"
                          Margin="0,0,8,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" Foreground="Black" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Content="🔄 창 목록 새로고침"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RefreshWindowsCommand}"/>
            </Grid>
        </Border>

        <!-- ── ORIGINAL TEXT ── -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource SectionHeader}"
                        Background="{StaticResource HeaderOrig}">
                    <TextBlock Text="원문" FontWeight="SemiBold"
                               Foreground="White" FontSize="13"/>
                </Border>
                <TextBox Grid.Row="1"
                         Text="{Binding OriginalText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextAccent}"
                         FontSize="14"
                         Margin="14,10"
                         MinHeight="80"/>
            </Grid>
        </Border>

        <!-- ── TRANSLATED TEXT ── -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource SectionHeader}"
                        Background="{StaticResource HeaderTrans}">
                    <TextBlock Text="번역문" FontWeight="SemiBold"
                               Foreground="White" FontSize="13"/>
                </Border>
                <TextBox Grid.Row="1"
                         Text="{Binding TranslatedText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextGreen}"
                         FontSize="14"
                         Margin="14,10"
                         MinHeight="80"/>
            </Grid>
        </Border>
    </Grid>
</Page>
